  <header>
    <div class="logo">FanLink</div>
    <nav>
      <a href="#home">Home</a>
      <a href="#membership">Membership Card</a>
      <a href="#meet">Meet & Greet</a>
      <a href="#contact">Contact</a>
      <a href="#login" class="btn" id="loginBtn">Login / Register</a>
    </nav>
  </header>

  <!-- Home Section -->
  <section id="home" class="hero">
    <h1>Welcome to FanLink</h1>
    <p>Connect with your favorite celebrities and get exclusive fan membership cards!</p>
    <a href="#membership" class="btn">Get Started</a>
  </section>

